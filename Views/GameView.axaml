<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Chess"
             xmlns:comp="clr-namespace:Chess.Modules"
             x:Class="Chess.Views.GameView">


    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Name="ButtonMenu"
                    Content="Menu"
                    Padding="10,5"
                    Margin="15"
            />

            <TextBlock Grid.Column="2" Name="TextBlack" HorizontalAlignment="Center" VerticalAlignment="Top" Text="Black's Turn" Margin="0, 20" FontSize="32" Opacity="0.2"></TextBlock>

        </Grid>
   
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
        
            <comp:Promotion Name="PromotionDialog"
                            Grid.Column="1"
                            Margin="40,0,0,0"
                            VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                
                <Grid Width="440" Height="440">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="400"/>
                        <RowDefinition Height="20"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="400"/>
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Row="0" Grid.Column="1" Name="TopLabels"/>
                    <Grid Grid.Row="2" Grid.Column="1" Name="BottomLabels"/>
                    <Grid Grid.Row="1" Grid.Column="0" Name="LeftLabels"/>
                    <Grid Grid.Row="1" Grid.Column="2" Name="RightLabels"/>

                    <Grid Grid.Row="1" Grid.Column="1">
                        <Grid Name="GameBoard"> </Grid>

                        <comp:OvCheckmate Name="CheckmateOverlay"/>

                    </Grid>
                </Grid>

            </StackPanel>

            <Grid Grid.Column="3" Margin="40,0,0,0" Height="440" VerticalAlignment="Center">
                <Grid>  

                    <Grid.RowDefinitions>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="400"/>
                        <RowDefinition Height="20"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Move" Height="20" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="Player" Height="20" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                </Grid>

                <comp:MoveListBox Name="MoveList"/>

            </Grid>

        </Grid>

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

           <TextBlock Grid.Column="2" Name="TextWhite" HorizontalAlignment="Center" VerticalAlignment="Bottom" Text="White's Turn" Margin="0, 20" FontSize="32"></TextBlock>

        </Grid>

        <comp:ConfirmationModal Name="MenuConf" ZIndex="1000" Grid.RowSpan="3"/>

    </Grid>

</UserControl>