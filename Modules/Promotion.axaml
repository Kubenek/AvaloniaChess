<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Chess.Modules.Promotion">
    
    <Grid Name="PromotionOverlay" IsVisible="false">
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="400"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Choose promotion:" 
                   HorizontalAlignment="Center" 
                   FontSize="16"/>
        
        <Grid Grid.Row="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Name="PromoteQueen" HorizontalAlignment="Center"
                    Content="♛" FontSize="60" Margin="10"/>
            <Button Grid.Row="1" Name="PromoteKnight" HorizontalAlignment="Center"
                    Content="♞" FontSize="60" Margin="10"/>
            <Button Grid.Row="2" Name="PromoteRook" HorizontalAlignment="Center"
                    Content="♜" FontSize="60" Margin="10"/>
            <Button Grid.Row="3" Name="PromoteBishop" HorizontalAlignment="Center"
                    Content="♝" FontSize="60" Margin="10"/>
        </Grid>
    </Grid>
</UserControl>