<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Chess"
             x:Class="Chess.Modules.ConfirmationModal">

    <Border Name="Modal" Background="#DE000000" VerticalAlignment="Center" HorizontalAlignment="Center" IsVisible="False" 
    Padding="20" CornerRadius="12">
            
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Name="ModalText" Text="" FontSize="20" FontWeight="Bold" Foreground="White" TextAlignment="Center"
            TextWrapping="Wrap" MaxWidth="325"/>

            <Button Grid.Row="1" Grid.Column="0" Name="btnYes" Content="Yes" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10, 20"/>
            <Button Grid.Row="1" Grid.Column="1" Name="btnNo" Content="No" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10, 20"/>
 
        </Grid>

    </Border>

</UserControl>